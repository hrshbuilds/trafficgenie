# TrafficGenie Frontend Configuration - SENSITIVE VALUES
# ============================================================================
# IMPORTANT: This file contains template values for environment variables.
# Copy this to .env.local and fill in your actual Firebase credentials.
# NEVER commit .env.local to git - it contains sensitive information!
# ============================================================================

# ============================================================================
# Firebase Configuration (Get from Firebase Console)
# https://console.firebase.google.com
# ============================================================================

# Your Firebase API Key (found in Project Settings > Web SDK snippet)
VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE

# Your Firebase Auth Domain (usually projectname.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=trafficgenie-a48a8.firebaseapp.com

# Your Firebase Project ID
VITE_FIREBASE_PROJECT_ID=trafficgenie-a48a8

# Your Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=trafficgenie-a48a8.firebasestorage.app

# Your Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE

# Your Firebase App ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID_HERE

# Your Firebase Measurement ID (optional)
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID_HERE

# ============================================================================
# API Configuration
# ============================================================================
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# Feature Flags (optional)
# ============================================================================
VITE_ENABLE_DEBUG=true

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Go to Firebase Console: https://console.firebase.google.com
# 2. Select "trafficgenie-a48a8" project
# 3. Go to Project Settings (gear icon)
# 4. Under "Your apps" section, find the web app
# 5. Copy the Firebase config values:
#    - apiKey → VITE_FIREBASE_API_KEY
#    - authDomain → VITE_FIREBASE_AUTH_DOMAIN (already filled)
#    - projectId → VITE_FIREBASE_PROJECT_ID (already filled)
#    - storageBucket → VITE_FIREBASE_STORAGE_BUCKET (already filled)
#    - messagingSenderId → VITE_FIREBASE_MESSAGING_SENDER_ID
#    - appId → VITE_FIREBASE_APP_ID
#    - measurementId → VITE_FIREBASE_MEASUREMENT_ID
# 6. Fill in the YOUR_XXX_HERE values above
# 7. Save as .env.local (not in git!)
# 8. Restart the dev server
#
# Also make sure to enable these in Firebase Console:
#   > Authentication > Sign-in method > Email/Password (Enabled)
#   > Firestore Database > Create in production mode
#   > Firestore Rules > Update to allow authenticated users
#
