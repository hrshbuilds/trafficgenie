# TrafficVision Backend Configuration
# Copy this to .env and fill in your values

# ============================================================================
# APP CONFIGURATION
# ============================================================================
ENV=development                          # development, staging, or production
DEBUG=True                               # Enable debug mode (dev only)
APP_NAME=TrafficVision
APP_VERSION=1.2.0

# ============================================================================
# SERVER
# ============================================================================
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api
ALLOWED_ORIGINS=*                        # CSV list or "*" (dev only). Use specific URLs in production.

# ============================================================================
# DATABASE (PostgreSQL for production, SQLite for dev)
# ============================================================================
# Development (SQLite):
# DATABASE_URL=sqlite:///./trafficvision.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/trafficvision

DATABASE_URL=sqlite:///./trafficvision.db
DB_ECHO=False                            # Log SQL queries (dev only)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ============================================================================
# FIREBASE
# ============================================================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com

# Option 1: Path to service account JSON file
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Option 2: Service account JSON as environment variable (recommended for production)
# FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"..."}'
FIREBASE_CREDENTIALS_JSON=

# ============================================================================
# GEMINI AI (for violation insights)
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ============================================================================
# FILE STORAGE
# ============================================================================
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/output
MAX_UPLOAD_SIZE_MB=500

# ============================================================================
# DETECTION MODELS
# ============================================================================
YOLO_MODEL_PATH=models/yolov8n.pt
HELMET_MODEL_PATH=                       # Optional specialized helmet model

# ============================================================================
# ASYNC JOB QUEUE (optional, for production)
# ============================================================================
REDIS_URL=                               # redis://localhost:6379/0 (leave empty to disable)
JOB_QUEUE_ENABLED=False

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO                           # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=text                          # text or json (use json in production)

# ============================================================================
# FEATURE FLAGS
# ============================================================================
DEMO_MODE=True                           # Enable demo auth bypass (dev only)
ENABLE_REAL_TIME_UPDATES=True            # Use Firebase Realtime listeners
ENABLE_GEMINI_INSIGHTS=True              # Generate AI insights for violations
